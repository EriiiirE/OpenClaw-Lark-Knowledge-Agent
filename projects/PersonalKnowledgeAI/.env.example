PKAI_API_KEY="your-api-key"
PKAI_BASE_URL="https://your-openai-compatible-endpoint/v1"
PKAI_MODEL="your-model-name"

# Optional generation toggle:
# PKAI_GENERATION_ENABLED="true"

# Optional local embedding:
# PKAI_EMBED_BACKEND="sentence-transformers"
# PKAI_VECTOR_MODEL="BAAI/bge-small-zh-v1.5"

# Optional cloud embedding:
# PKAI_EMBED_BACKEND="openai-compatible"
# PKAI_EMBED_API_KEY="your-embedding-api-key"
# PKAI_EMBED_BASE_URL="https://your-openai-compatible-endpoint/v1"
# PKAI_EMBED_MODEL="your-embedding-model"

# Optional DashScope embedding:
# DASHSCOPE_API_KEY="your-dashscope-key"
# PKAI_DASHSCOPE_EMBED_MODEL="text-embedding-v4"

# Optional chunking and vector store:
# PKAI_CHUNK_LLM_ENABLED="false"
# PKAI_VECTOR_STORE_BACKEND="local"
# PKAI_MILVUS_URI="http://127.0.0.1:19530"
# PKAI_MILVUS_COLLECTION="pkai_chunks"
